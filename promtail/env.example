# Copy to promtail/.env on the app VM:  cp promtail/env.example promtail/.env
#
# Push URL must match Loki's HTTP path. With path_prefix /loki (monitoring/loki/loki-config.yaml):
LOKI_URL=http://<IP>:3100/loki/api/v1/push
#
# If you removed path_prefix from Loki, use instead:
# LOKI_URL=http://<IP>:3100/api/v1/push
#
# Monitoring host must allow TCP 3100 from this VM. Test from app VM:
#   curl -sS -o /dev/null -w "%{http_code}\n" http://<IP>:3100/loki/ready
