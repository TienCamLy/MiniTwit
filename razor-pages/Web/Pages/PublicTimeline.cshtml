@page "/public"
@using Web.API.Misc
@model Web.Pages.PublicTimelineModel
@{
    ViewData["Title"] = "Public Timeline";
}

<div>
    <header>
        <h2>Public Timeline</h2>
    </header>

    <ul class="messages">
        @if (Model.Messages.Any())
        {
            @foreach (var message in Model.Messages)
            {
                <li>
                    <img src="@Helpers.GenerateGravatarUrl(message.AuthorEmail)" alt="avatar"/>
                    <strong><a href="/@message.AuthorName">@message.AuthorName</a></strong>
                    @message.Text
                    <small>&mdash; @message.PubDate</small>
                </li>
            }
        }
        else
        {
            <li><em>There's no message so far.</em></li>
        }
    </ul>
    <div class="pagination">
        @if (Model.PageNumber - 5 > 1)
        {
            <a href="/public?Page=1" class="first">First</a>
        }
        @if (Model.PageNumber > 1)
        {
            <a href="/public?Page=@(Model.PageNumber - 1)" class="prev">Previous</a>
        }

        @for (int i = Math.Max(1, Model.PageNumber - 5); i <= Math.Min(Model.TotalPages, Model.PageNumber + 5); i++)
        {
            if (i == Model.PageNumber)
            {
                <span class="current">@i</span>
            }
            else
            {
                <a href="/public?Page=@i">@i</a>
            }
        }

        @if (Model.PageNumber < Model.TotalPages)
        {
            <a href="/public?Page=@(Model.PageNumber + 1)" class="next">Next</a>
        }
        @if (Model.PageNumber + 5 < Model.TotalPages)
        {
            <a href="/public?Page=@(Model.TotalPages)" class="last">Last</a>
        }
    </div>
</div>