@page "/register"
@model RegisterModel
@{
    ViewData["Title"] = "Sign Up";
}

<h2>Sign Up</h2>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="error"><strong>Error:</strong> @Model.Error</div>
}

<form method="post">
    <dl>
        <dt>Username:
        <dd><input type="text" asp-for="Username" size="30" />
        <dt>E-Mail:
        <dd><input type="text" asp-for="Email" size="30" />
        <dt>Password:
        <dd><input type="password" asp-for="Password" size="30" />
        <dt>Password <small>(repeat)</small>:
        <dd><input type="password" asp-for="Password2" size="30" />
    </dl>
    <div class="actions"><input type="submit" value="Sign Up"/></div>
</form>