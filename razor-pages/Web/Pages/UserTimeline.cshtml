@page "/{user}/{error?}"
@using Web.API.Misc
@model UserTimelineModel
@{
    ViewData["Title"] = Model.Username + "'s Timeline";
    Layout = "Shared/_Layout";
}
@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="error"><strong>Error:</strong> @Model.Error</div>
}

<div>
    <header>
        <h2> @(Model.Username)'s Timeline </h2> 
    </header>
    
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="followstatus">
            @if (Model.Username == User.Identity?.Name) 
            { 
                @:This is you!
            }
            else if (Model.Followed)
            {
                <form method="post" id="unfollowForm"></form>
                @:You are currently following this user. <a href="#" onclick="document.getElementById('unfollowForm').submit(); return false;">Unfollow user</a>.
            }
            else
            {
                <form method="post" id="followForm"></form>
                @:You are not yet following this user. <a href="#" onclick="document.getElementById('followForm').submit(); return false;">Follow user</a>.
            }
        </div>
    }
    <ul class="messages">
        @if (Model.Messages.Any())
        {
            @foreach (var message in Model.Messages)
            {
                <li>
                    <img src="@Helpers.GenerateGravatarUrl(message.AuthorEmail)"/>
                    <strong><a href="/@message.AuthorName">@message.AuthorName</a></strong>
                    @message.Text
                    <small>&mdash; @message.PubDate </small>
                </li>
            }
        }
        else
        {
            <li><em>There's no message so far.</em></li>
        }
    </ul>
    <div class="pagination">
        @if (Model.PageNumber - 5 > 1)
        {
            <a href="/@(Model.Username)?Page=1" class="first">First</a>
        }
        @if (Model.PageNumber > 1)
        {
            <a href="/@(Model.Username)?Page=@(Model.PageNumber - 1)" class="prev">Previous</a>
        }

        @for (int i = Math.Max(1, Model.PageNumber - 5); i <= Math.Min(Model.TotalPages, Model.PageNumber + 5); i++)
        {
            if (i == Model.PageNumber)
            {
                <span class="current">@i</span>
            }
            else
            {
                <a href="/@(Model.Username)?Page=@i">@i</a>
            }
        }

        @if (Model.PageNumber < Model.TotalPages)
        {
            <a href="/@(Model.Username)?Page=@(Model.PageNumber + 1)" class="next">Next</a>
        }
        @if (Model.PageNumber + 5 < Model.TotalPages)
        {
            <a href="/@(Model.Username)?Page=@(Model.TotalPages)" class="last">Last</a>
        }
    </div>
</div>
