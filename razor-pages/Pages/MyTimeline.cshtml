@page "/"
@using razor_pages.Misc
@model MyTimelineModel
@{
    ViewData["Title"] = "My Timeline";
    Layout = "Shared/_Layout";
}

<div>
    <header>
        <h2> My Timeline </h2> 
    </header>
    
    <div class=twitbox>
        <h3>What's on your mind @User.Identity?.Name?</h3>
        <form method="post">
            <p>
                <input type="text" name="text" size="60"><!--
                --><input type="submit" value="Share">
            </p>
        </form>
    </div>

    <ul class="messages">
        @if (Model.Messages.Any())
        {
            @foreach (var message in Model.Messages)
            {
                <li><img src="@Helpers.GenerateGravatarUrl(message.author.email)"/>
                    <strong><a href="/@message.author.name"> @message.author.name </a></strong>
                    @message.text
                    <small>&mdash; @message.pub_date.ToString("yyyy-MM-dd @ HH:mm") </small>
                </li>
            }
        }
        else
        {
            <li><em>There's no message so far.</em></li>
        }
    </ul>
</div>